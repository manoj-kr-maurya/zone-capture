// Prisma schema for MongoDB used by the Run For Zone backend
// Note: Set DATABASE_URL in your .env to connect to a MongoDB instance.

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Runner {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  name      String
  path      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Zone {
  id         String   @id @map("_id") @default(auto()) @db.ObjectId
  ownerId    String   @db.ObjectId
  polygon    Json
  capturedAt DateTime @default(now())
}
